{
  "meta": {
    "difficulty": "easy",
    "topics": ["stack", "strings"]
  },
  "cases": [
    {"name": "empty",                 "args": [""],         "expected": true},
    {"name": "single pair",           "args": ["()"],       "expected": true},
    {"name": "all types in sequence", "args": ["()[]{}"],   "expected": true},
    {"name": "nested",                "args": ["{[()]}"],   "expected": true},
    {"name": "tricky: interleaved",   "args": ["([)]"],     "expected": false},
    {"name": "right before left",     "args": [")("],       "expected": false},
    {"name": "unclosed",              "args": ["((("],      "expected": false},
    {"name": "unmatched closer",      "args": ["{[]}]"],    "expected": false}
  ]
}
