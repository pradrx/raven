#!/usr/bin/env python3
"""raven — local LeetCode-style harness.

Subcommands:
  run <slug-or-path>     Run user's `solve` against the matching test file.
  list [--difficulty X]  List questions and their metadata.
       [--topic Y]
  show <slug-or-path>    Show the question docstring + meta. Hides cases.

Triples are matched by relative path:
    questions/<rel>.py <-> tests/<rel>.json <-> specs/<rel>.md
Slugs (the file stem) are globally unique across the entire questions/ tree.
"""

from __future__ import annotations

import argparse
import ast
import contextlib
import importlib.util
import io
import json
import os
import pprint
import re
import sys
import traceback
import uuid
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent
QUESTIONS_DIR = REPO_ROOT / "questions"
TESTS_DIR = REPO_ROOT / "tests"
SPECS_DIR = REPO_ROOT / "specs"

SLUG_RE = re.compile(r"^[a-z][a-z0-9_-]*$")

DIFFICULTIES = ("easy", "medium", "hard")
OUTPUT_LINE_CAP = 20

_USE_COLOR = sys.stdout.isatty() and not os.environ.get("NO_COLOR")
_ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")


def color(text: str, code: str) -> str:
    if not _USE_COLOR:
        return text
    return f"\x1b[{code}m{text}\x1b[0m"


def visible_len(s: str) -> int:
    return len(_ANSI_RE.sub("", s))


GREEN = "32"
RED = "31"


def validate_token(token: str, kind: str) -> None:
    if not SLUG_RE.match(token):
        raise SystemExit(
            f"error: invalid {kind} '{token}'. "
            f"Must match [a-z][a-z0-9_-]* (lowercase letter, then letters/digits/_/-)."
        )


def parse_path_style(arg: str) -> tuple[tuple[str, ...], str]:
    if arg.startswith("/"):
        arg = arg[1:]
    if not arg:
        raise SystemExit("error: empty slug")
    if arg.endswith("/"):
        raise SystemExit(f"error: trailing '/' in argument; expected <folder>/<slug>")
    parts = arg.split("/")
    kind = "path segment" if len(parts) > 1 else "slug"
    for part in parts:
        validate_token(part, kind)
    return tuple(parts[:-1]), parts[-1]


def build_slug_index() -> dict[str, Path]:
    index: dict[str, Path] = {}
    if not QUESTIONS_DIR.is_dir():
        return index
    for path in sorted(QUESTIONS_DIR.rglob("*.py")):
        rel = path.relative_to(QUESTIONS_DIR)
        if any(part.startswith((".", "_")) for part in rel.parts):
            continue
        for segment in rel.parts[:-1]:
            validate_token(segment, "folder segment")
        slug = path.stem
        validate_token(slug, "slug")
        if slug in index:
            raise SystemExit(
                f"error: duplicate slug '{slug}' found at:\n"
                f"    {index[slug].relative_to(REPO_ROOT)}\n"
                f"    {path.relative_to(REPO_ROOT)}\n"
                f"Slugs must be globally unique. Rename one of these files "
                f"(and its matching test/spec) before running raven again."
            )
        index[slug] = path
    return index


def resolve_slug(arg: str) -> tuple[str, Path]:
    folder, slug = parse_path_style(arg)
    index = build_slug_index()
    if slug not in index:
        raise SystemExit(
            f"error: no question with slug '{slug}'. "
            f"Run ./raven list to see available slugs."
        )
    qpath = index[slug]
    actual_folder = qpath.relative_to(QUESTIONS_DIR).parts[:-1]
    if folder and folder != actual_folder:
        actual_rel = qpath.relative_to(QUESTIONS_DIR)
        requested_rel = "/".join((*folder, f"{slug}.py"))
        raise SystemExit(
            f"error: slug '{slug}' lives at questions/{actual_rel}, "
            f"not questions/{requested_rel}"
        )
    return slug, qpath


def paths_for(question_path: Path) -> tuple[Path, Path, Path]:
    base = question_path.relative_to(QUESTIONS_DIR).with_suffix("")
    return (
        question_path,
        (TESTS_DIR / base).with_suffix(".json"),
        (SPECS_DIR / base).with_suffix(".md"),
    )


def load_test_file(test_path: Path) -> dict:
    if not test_path.is_file():
        raise SystemExit(f"error: no test file at {test_path.relative_to(REPO_ROOT)}")
    with test_path.open() as f:
        return json.load(f)


def load_question_module(question_path: Path):
    if not question_path.is_file():
        raise SystemExit(f"error: no question file at {question_path.relative_to(REPO_ROOT)}")
    mod_name = f"raven_q_{uuid.uuid4().hex}"
    spec = importlib.util.spec_from_file_location(mod_name, question_path)
    if spec is None or spec.loader is None:
        raise SystemExit(f"error: could not load question file: {question_path}")
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


def fmt(value) -> str:
    try:
        return repr(value)
    except Exception:
        return "<unrepr-able>"


def pfmt_field(prefix: str, value) -> str:
    try:
        text = pprint.pformat(value, width=80, compact=True)
    except Exception:
        text = "<unrepr-able>"
    if "\n" not in text:
        return prefix + text
    pad = " " * visible_len(prefix)
    first, *rest = text.split("\n")
    return prefix + first + "\n" + "\n".join(pad + line for line in rest)


def format_traceback(exc: BaseException) -> str:
    tb = exc.__traceback__
    if tb is not None and tb.tb_next is not None:
        tb = tb.tb_next
    text = "".join(traceback.format_exception(type(exc), exc, tb)).rstrip("\n")
    return "\n".join(f"        {line}" for line in text.split("\n"))


def format_captured(buf: io.StringIO) -> str | None:
    raw = buf.getvalue()
    if not raw:
        return None
    if raw.endswith("\n"):
        raw = raw[:-1]
    lines = raw.split("\n")
    overflow = len(lines) - OUTPUT_LINE_CAP
    if overflow > 0:
        lines = lines[:OUTPUT_LINE_CAP]
        lines.append(f"... [truncated {overflow} more line(s)]")
    indented = "\n".join(f"        {line}" for line in lines)
    return f"        ----- captured output -----\n{indented}"


def cmd_run(args: argparse.Namespace) -> int:
    slug, qpath = resolve_slug(args.slug)
    _, tpath, _ = paths_for(qpath)
    data = load_test_file(tpath)
    cases = data.get("cases")
    if not isinstance(cases, list) or not cases:
        raise SystemExit(
            f"error: {tpath.relative_to(REPO_ROOT)} must have a non-empty 'cases' list"
        )

    module = load_question_module(qpath)
    solve = getattr(module, "solve", None)
    if not callable(solve):
        raise SystemExit(
            f"error: {qpath.relative_to(REPO_ROOT)} must define a callable `solve`"
        )

    print(f"running {len(cases)} case(s) for {slug}")
    total = len(cases)
    passed = 0
    first_failure: tuple[int, list, object, object, Exception | None, str | None] | None = None
    for i, case in enumerate(cases, 1):
        case_args = case.get("args", [])
        expected = case.get("expected")

        buf = io.StringIO()
        raised: Exception | None = None
        actual = None
        with contextlib.redirect_stdout(buf), contextlib.redirect_stderr(buf):
            try:
                actual = solve(*case_args)
            except Exception as e:
                raised = e

        if raised is None and actual == expected:
            passed += 1
            continue

        if first_failure is None:
            first_failure = (i, case_args, expected, actual, raised, format_captured(buf))

    if first_failure is None:
        for i, case in enumerate(cases, 1):
            print(f"  [{i}] {color('PASS', GREEN)}  args={fmt(case.get('args', []))}")
    else:
        i, case_args, expected, actual, raised, captured = first_failure
        print(pfmt_field(f"  [{i}] {color('FAIL', RED)}  args=", case_args))
        if raised is not None:
            print(format_traceback(raised))
        else:
            print(pfmt_field("        expected=", expected))
            print(pfmt_field("        actual  =", actual))
        if captured is not None:
            print(captured)

    summary = f"{passed}/{total} passed"
    print("\n" + color(summary, GREEN if passed == total else RED))
    return 0 if passed == total else 1


def _read_test_meta(test_path: Path) -> dict | None:
    try:
        with test_path.open() as f:
            return json.load(f).get("meta")
    except Exception:
        return None


def collect_questions() -> list[tuple[str, tuple[str, ...], dict | None, str | None]]:
    """Returns (slug, folder, meta, status) rows.

    status is None for healthy pairs, "orphan-question" if no test exists at
    the mirrored path, "orphan-test" if a test has no matching question.
    """
    qindex = build_slug_index()
    rows: list[tuple[str, tuple[str, ...], dict | None, str | None]] = []
    seen_slugs: set[str] = set()

    for slug, qpath in qindex.items():
        seen_slugs.add(slug)
        folder = qpath.relative_to(QUESTIONS_DIR).parts[:-1]
        _, tpath, _ = paths_for(qpath)
        if not tpath.is_file():
            rows.append((slug, folder, None, "orphan-question"))
            continue
        rows.append((slug, folder, _read_test_meta(tpath), None))

    if TESTS_DIR.is_dir():
        for tpath in sorted(TESTS_DIR.rglob("*.json")):
            rel = tpath.relative_to(TESTS_DIR)
            if any(part.startswith((".", "_")) for part in rel.parts):
                continue
            slug = tpath.stem
            if slug in seen_slugs:
                continue
            folder = rel.parts[:-1]
            rows.append((slug, folder, _read_test_meta(tpath), "orphan-test"))

    rows.sort(key=lambda r: ((not r[1]), r[1], r[0]))
    return rows


def _format_difficulty(difficulty: str) -> str:
    return f"[{difficulty}]".ljust(8)


def cmd_list(args: argparse.Namespace) -> int:
    rows = collect_questions()
    if not rows:
        print("(no questions yet)")
        return 0

    want_difficulty = args.difficulty
    want_topic = args.topic

    filtered: list[tuple[str, tuple[str, ...], str, list[str], str | None, bool]] = []
    for slug, folder, meta, status in rows:
        if meta is None:
            difficulty, topics, meta_missing = "?", [], True
        else:
            difficulty = meta.get("difficulty", "?")
            topics = meta.get("topics") or []
            meta_missing = "difficulty" not in meta or "topics" not in meta
        if want_difficulty and difficulty != want_difficulty:
            continue
        if want_topic and want_topic not in topics:
            continue
        filtered.append((slug, folder, difficulty, topics, status, meta_missing))

    if not filtered:
        print("(no questions match)")
        return 0

    groups: dict[tuple[str, ...], list[tuple[str, str, list[str], str | None, bool]]] = {}
    for slug, folder, difficulty, topics, status, meta_missing in filtered:
        groups.setdefault(folder, []).append((slug, difficulty, topics, status, meta_missing))

    sorted_folders = sorted(groups.keys(), key=lambda f: ((not f), f))

    for i, folder in enumerate(sorted_folders):
        if i > 0:
            print()
        header = "(root)" if not folder else "/".join(folder) + "/"
        print(header)
        entries = sorted(groups[folder], key=lambda e: e[0])
        slug_w = max(len(e[0]) for e in entries)
        for slug, difficulty, topics, status, meta_missing in entries:
            topics_str = ", ".join(topics) if topics else "-"
            flags: list[str] = []
            if status == "orphan-question":
                flags.append("(missing test)")
            elif status == "orphan-test":
                flags.append("(missing question)")
            elif meta_missing:
                flags.append("(meta missing)")
            flag_str = ("  " + " ".join(flags)) if flags else ""
            diff_str = _format_difficulty(difficulty)
            print(f"  {slug:<{slug_w}}  {diff_str}  {topics_str}{flag_str}")
    return 0


def read_module_docstring(question_path: Path) -> str | None:
    if not question_path.is_file():
        raise SystemExit(f"error: no question file at {question_path.relative_to(REPO_ROOT)}")
    with question_path.open() as f:
        tree = ast.parse(f.read(), filename=str(question_path))
    return ast.get_docstring(tree)


def cmd_show(args: argparse.Namespace) -> int:
    slug, qpath = resolve_slug(args.slug)
    _, tpath, _ = paths_for(qpath)
    docstring = read_module_docstring(qpath)
    data = load_test_file(tpath)
    meta = data.get("meta") or {}

    print(f"# {slug}")
    print()
    if meta:
        difficulty = meta.get("difficulty", "?")
        topics = ", ".join(meta.get("topics") or []) or "-"
        print(f"difficulty: {difficulty}")
        print(f"topics:     {topics}")
        print()
    else:
        print("(no meta)")
        print()

    if docstring:
        print(docstring.strip())
    else:
        print("(no docstring)")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="raven", description=__doc__.splitlines()[0])
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_run = sub.add_parser("run", help="run a question against its tests")
    p_run.add_argument("slug", help="slug or folder/path/slug")
    p_run.set_defaults(func=cmd_run)

    p_list = sub.add_parser("list", help="list questions")
    p_list.add_argument("--difficulty", choices=DIFFICULTIES)
    p_list.add_argument("--topic")
    p_list.set_defaults(func=cmd_list)

    p_show = sub.add_parser("show", help="show a question's docstring + meta (no cases)")
    p_show.add_argument("slug", help="slug or folder/path/slug")
    p_show.set_defaults(func=cmd_show)

    return parser


def main(argv: list[str]) -> int:
    args = build_parser().parse_args(argv[1:])
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main(sys.argv))
